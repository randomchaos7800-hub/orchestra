# Orchestra — environment variables
# Copy to .env and fill in your values.
# python-dotenv loads this automatically if installed.

# API key for your fallback LLM endpoint (OpenRouter, OpenAI, etc.)
# The env var name must match fallback_api_key_env in config/config.json
OPENROUTER_API_KEY=your-key-here

# Optional: add a delay (seconds) between LLM calls to avoid rate limits.
# Useful when using a remote API with strict rate limits.
# Default: 0 (no delay). Typical: 0.5 for OpenRouter free tier.
# ORCHESTRA_REQUEST_DELAY=0.5
